#pragma once

#define LLMCORE_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define LLMCORE_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define LLMCORE_VERSION_PATCH @PROJECT_VERSION_PATCH@

#define LLMCORE_VERSION_STRING "@PROJECT_VERSION@"

#define LLMCORE_VERSION_CHECK(major, minor, patch) \
    ((major << 16) | (minor << 8) | (patch))

#define LLMCORE_VERSION \
    LLMCORE_VERSION_CHECK(LLMCORE_VERSION_MAJOR, LLMCORE_VERSION_MINOR, LLMCORE_VERSION_PATCH)
